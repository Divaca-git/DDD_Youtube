<mxfile host="app.diagrams.net" type="device">
  <diagram id="descubrimiento-secuencia" name="Descubrimiento - Secuencia: indexar y servir feed">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Lineas de vida ===== -->
        <mxCell id="lf_catalogo" value="Catálogo&#10;(contexto 2)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="120" height="600" as="geometry" />
        </mxCell>
        <mxCell id="lf_bus" value="Bus de eventos" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="240" y="40" width="120" height="600" as="geometry" />
        </mxCell>
        <mxCell id="lf_descubrimiento" value="Descubrimiento&#10;(contexto 3)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="450" y="40" width="130" height="600" as="geometry" />
        </mxCell>
        <mxCell id="lf_viewer" value="Espectador" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;" vertex="1" parent="1">
          <mxGeometry x="680" y="40" width="120" height="600" as="geometry" />
        </mxCell>
        <mxCell id="lf_catalogo2" value="Catálogo&#10;(consulta visibilidad)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;" vertex="1" parent="1">
          <mxGeometry x="900" y="40" width="130" height="600" as="geometry" />
        </mxCell>

        <!-- ===== FASE 1: Indexación por evento ===== -->
        <mxCell id="fase1" value="FASE 1 — Indexación reactiva (RF-D6, sin endpoints)" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=left;verticalAlign=middle;fontStyle=1;fontSize=11;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="990" height="24" as="geometry" />
        </mxCell>

        <mxCell id="m1" value="ContenidoPublicado" style="html=1;rounded=0;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="150" as="sourcePoint" />
            <mxPoint x="300" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="ContenidoPublicado" style="html=1;rounded=0;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="180" as="sourcePoint" />
            <mxPoint x="515" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="mself1" value="indexa el ítem (crea ItemIndexado)" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="205" as="sourcePoint" />
            <mxPoint x="515" y="235" as="targetPoint" />
            <Array as="points">
              <mxPoint x="600" y="205" />
              <mxPoint x="600" y="235" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== FASE 2: Servir feed ===== -->
        <mxCell id="fase2" value="FASE 2 — Servir feed personalizado (RF-D2) con validación de visibilidad (RNF-5)" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=left;verticalAlign=middle;fontStyle=1;fontSize=11;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="990" height="24" as="geometry" />
        </mxCell>

        <mxCell id="m3" value="1. GET /feed" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="740" y="330" as="sourcePoint" />
            <mxPoint x="515" y="330" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="mself2" value="rankea candidatos según perfil de intereses + señales" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="355" as="sourcePoint" />
            <mxPoint x="515" y="385" as="targetPoint" />
            <Array as="points">
              <mxPoint x="600" y="355" />
              <mxPoint x="600" y="385" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Validacion sincrona de visibilidad (fragmento opt) -->
        <mxCell id="optframe" value="opt  [ítems sensibles: validar antes de servir]" style="shape=umlFrame;whiteSpace=wrap;html=1;width=200;height=26;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="495" y="410" width="470" height="96" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="2. GET /contenidos/{id}/visibilidad" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="450" as="sourcePoint" />
            <mxPoint x="965" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m4r" value="200 visible: true | false" style="html=1;rounded=0;dashed=1;endArrow=open;endFill=0;endSize=12;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="965" y="480" as="sourcePoint" />
            <mxPoint x="515" y="480" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="m5" value="3. 200 feed (referencias + motivo, ya filtrado)" style="html=1;rounded=0;dashed=1;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="535" as="sourcePoint" />
            <mxPoint x="740" y="535" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Senal de impresion -->
        <mxCell id="m6" value="4. POST /senales/impresion" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="740" y="575" as="sourcePoint" />
            <mxPoint x="515" y="575" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m6r" value="202 aceptada" style="html=1;rounded=0;dashed=1;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="603" as="sourcePoint" />
            <mxPoint x="740" y="603" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== Leyenda ===== -->
        <mxCell id="leyenda" value="Notación: flecha rellena = síncrona · flecha abierta = evento asíncrono · punteada = respuesta · marco opt = paso opcional. FASE 1: el índice se mantiene SOLO, reaccionando a eventos de Catálogo (RF-D6 sin endpoints = bajo acoplamiento). FASE 2: antes de servir, Descubrimiento puede validar visibilidad de forma síncrona contra Catálogo (RNF-4/RNF-5), filtrando ítems despublicados. Descubrimiento NO define visibilidad: la respeta." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=#d6b656;align=left;spacing=8;fontSize=11;size=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="990" height="120" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
