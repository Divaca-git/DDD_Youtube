    <mxCell id="nota_rnf2" value="RNF-2: este contexto comparte IDs (channelId, catalogItemId,&#xa;userId) pero NO modelos de Catálogo, Audiencia ni Publicación.&#xa;'Canal' aquí solo tiene saldo y estado económico." style="text;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;spacingLeft=6;rounded=1;fontSize=9;" vertex="1" parent="1">
