    <mxCell id="f5_e1" value="POST /impresiones { adDecisionId: X } — llega DESPUÉS del agotamiento" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="645" y="722" as="sourcePoint" /><mxPoint x="280" y="722" as="targetPoint" /></mxGeometry>
    </mxCell>
    <mxCell id="f5_note1" value="AdDecision X está en estado 'expirada' (PresupuestoAgotado ya procesado)" style="text;fontSize=9;fillColor=#f8cecc;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="734" width="380" height="16" as="geometry" />
    </mxCell>
    <mxCell id="f5_e2" value="409 { codigo: PRESUPUESTO_AGOTADO } — impresión rechazada, anunciante no facturado" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="280" y="762" as="sourcePoint" /><mxPoint x="645" y="762" as="targetPoint" /></mxGeometry>
    </mxCell>

    <mxCell id="f5_e3" value="PresupuestoAgotado { campaignId } (async) — emitido cuando presupuestoRestante llega a 0" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="280" y="792" as="sourcePoint" /><mxPoint x="460" y="792" as="targetPoint" /></mxGeometry>
    </mxCell>
    <mxCell id="f5_note2" value="RNF-5: la ventana entre AdDecision 'servido' y la confirmación de impresión&#xa;es la zona de riesgo. Las AdDecision en vuelo quedan 'expiradas' al agotarse&#xa;el presupuesto. El anunciante NUNCA es facturado por impresiones posteriores." style="text;fontSize=9;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;align=left;spacingLeft=4;" vertex="1" parent="1">
      <mxGeometry x="60" y="820" width="540" height="48" as="geometry" />
    </mxCell>

