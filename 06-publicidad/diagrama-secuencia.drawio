    <mxCell id="f5_label" value="FASE 5 — Consistencia eventual (RNF-5): presupuesto agotado durante decisiones en vuelo" style="text;fontStyle=2;fontSize=10;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
