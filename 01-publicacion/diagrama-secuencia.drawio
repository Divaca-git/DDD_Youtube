<mxfile host="app.diagrams.net" type="device">
  <diagram id="publicacion-secuencia" name="Publicacion - Secuencia: de la subida al catalogo">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Lineas de vida ===== -->
        <mxCell id="lf_creador" value="Creador" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="120" height="540" as="geometry" />
        </mxCell>
        <mxCell id="lf_publicacion" value="Publicación&#10;(contexto 1)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="240" y="40" width="120" height="540" as="geometry" />
        </mxCell>
        <mxCell id="lf_bus" value="Bus de eventos" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="460" y="40" width="120" height="540" as="geometry" />
        </mxCell>
        <mxCell id="lf_catalogo" value="Catálogo&#10;(contexto 2)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;" vertex="1" parent="1">
          <mxGeometry x="660" y="40" width="120" height="540" as="geometry" />
        </mxCell>

        <!-- ===== Fragmento loop (subida por partes) ===== -->
        <mxCell id="loopframe" value="loop  [por cada parte]" style="shape=umlFrame;whiteSpace=wrap;html=1;width=170;height=26;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="178" width="330" height="96" as="geometry" />
        </mxCell>

        <!-- ===== Mensajes ===== -->

        <mxCell id="m1" value="1. POST /subidas" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="120" as="sourcePoint" />
            <mxPoint x="300" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m1r" value="201 uploadId" style="html=1;rounded=0;dashed=1;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="148" as="sourcePoint" />
            <mxPoint x="100" y="148" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="m2" value="2. PUT /subidas/{id}/partes/{n}" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="210" as="sourcePoint" />
            <mxPoint x="300" y="210" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m2r" value="200 progreso" style="html=1;rounded=0;dashed=1;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="245" as="sourcePoint" />
            <mxPoint x="100" y="245" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="m3" value="3. POST /subidas/{id}/completar" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="305" as="sourcePoint" />
            <mxPoint x="300" y="305" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="ContenidoSubido" style="html=1;rounded=0;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="335" as="sourcePoint" />
            <mxPoint x="520" y="335" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m3r" value="201 VideoAsset (procesamiento pendiente)" style="html=1;rounded=0;dashed=1;endArrow=open;endFill=0;endSize=12;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="365" as="sourcePoint" />
            <mxPoint x="100" y="365" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="mself" value="procesamiento asíncrono: genera calidades (RF-P2)" style="html=1;rounded=0;endArrow=block;endFill=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="400" as="sourcePoint" />
            <mxPoint x="300" y="430" as="targetPoint" />
            <Array as="points">
              <mxPoint x="385" y="400" />
              <mxPoint x="385" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m5" value="ProcesamientoFinalizado (éxito)" style="html=1;rounded=0;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="462" as="sourcePoint" />
            <mxPoint x="520" y="462" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="AssetListoParaPublicacion" style="html=1;rounded=0;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="492" as="sourcePoint" />
            <mxPoint x="520" y="492" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="AssetListoParaPublicacion" style="html=1;rounded=0;endArrow=open;endFill=0;endSize=12;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="520" as="sourcePoint" />
            <mxPoint x="720" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== Notas ===== -->
        <mxCell id="nota_catalogo" value="Catálogo registra el asset como vinculable. Desde aquí continúa el flujo del diagrama de secuencia de Catálogo (POST /contenidos, publicar)." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=#d6b656;align=left;spacing=8;fontSize=11;size=14;" vertex="1" parent="1">
          <mxGeometry x="640" y="600" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="leyenda" value="Notación: flecha rellena = llamada síncrona (espera respuesta) · flecha abierta = evento asíncrono (no espera) · punteada = respuesta · marco loop = repetición (fragmento de la Clase 03). Detalle clave: el 201 de completar se responde ANTES de que termine el procesamiento; los resultados llegan después por eventos." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=#d6b656;align=left;spacing=8;fontSize=11;size=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="560" height="110" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
